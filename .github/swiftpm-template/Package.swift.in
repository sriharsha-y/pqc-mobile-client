// swift-tools-version: 5.7
// AUTO-GENERATED by .github/workflows/release.yml — publish-swiftpm job.
// Edit .github/swiftpm-template/Package.swift.in on the main branch;
// changes are propagated to the swiftpm branch by the next release.

import PackageDescription

let version = "{{VERSION}}"

let package = Package(
    name: "PqcCore",
    platforms: [.iOS(.v13)],
    products: [
        .library(name: "PqcCore", targets: ["PqcCore"])
    ],
    targets: [
        // PqcCore-X.Y.Z.xcframework.zip is a slim archive — just the
        // .xcframework, no other top-level entries — which is what
        // Apple's "Distributing Binary Frameworks as Swift Packages"
        // doc shows. CocoaPods uses a separate (fat) zip with the same
        // xcframework + pqc.swift + LICENSE; both zips are produced by
        // the same release workflow.
        //
        // The binaryTarget name MUST match the xcframework's modulemap
        // module name ("pqcFFI" — declared in module.modulemap). When
        // they diverge, consumers can hit "no such module pqcFFI" at
        // build time even though SPM resolved the binaryTarget fine,
        // because the modulemap's name is what the Swift compiler sees.
        .binaryTarget(
            name: "pqcFFI",
            url: "https://github.com/sriharsha-y/pqc-mobile-client/releases/download/v\(version)/PqcCore-\(version).xcframework.zip",
            checksum: "{{CHECKSUM}}"
        ),
        // Swift binding generated by UniFFI; lives under Sources/PqcCore
        // on the swiftpm branch (the workflow extracts pqc.swift out of
        // the release zip and places it there). pqc.swift contains
        // `import pqcFFI` which now matches both the modulemap and the
        // binaryTarget name.
        .target(
            name: "PqcCore",
            dependencies: ["pqcFFI"],
            path: "Sources/PqcCore"
        )
    ]
)
