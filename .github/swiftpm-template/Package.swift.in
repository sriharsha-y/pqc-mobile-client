import PackageDescription

let version = "{{VERSION}}"

let package = Package(
    name: "PqcCore",
    platforms: [.iOS(.v13)],
    products: [
        .library(name: "PqcCore", targets: ["PqcCore"])
    ],
    targets: [
        // PqcCore-X.Y.Z.zip contains PqcCore.xcframework at its top level
