# Rust
target/
**/*.rs.bk

# UniFFI generated artifacts (regenerate from source)
generated/

# Swift Package Manager local resolve / build cache. Created whenever
# Xcode or `swift build` touches Package.swift (artifacts/, checkouts/,
# repositories/, index-build/, workspace-state.json). Machine-local.
.build/

# IDE
.idea/
.vscode/
*.iml

# macOS
.DS_Store

# Android — Gradle build outputs and tooling caches for the library
# module rooted at android/.
android/build/
android/.gradle/
android/.kotlin/
android/local.properties
local.properties

# Auto-extracted upstream jars (rustls-platform-verifier Kotlin glue,
# pulled out of the vendored Maven AAR by scripts/build-android.sh).
# Regenerated on every build; not source.
android/libs/

# iOS
*.xcuserstate
xcuserdata/

# Repo-root symlinks created by scripts/build-ios.sh so the local
# PqcCore.podspec :path consumption finds the bare names the published
# podspec uses. Pure build artefacts; the real files live under generated/
# (for pqc.swift / PqcCore.xcframework) or Sources/PqcCore/ (for the
# hand-written wrappers).
/PqcCore.xcframework
/pqc.swift
/PqcConfig+Defaults.swift
/PqcURLProtocol.swift

# Logs / scratch
*.log
.scratch/

# Local-only planning / audit notes (kept out of version control on purpose).
docs/AUDIT.md
docs/HTTP3_PLAN.md

# Claude Code per-user, machine-local state. The project-level CLAUDE.md
# at the repo root IS tracked — it's the load-bearing project guide for
# Claude Code (and referenced in the system prompt as "checked into the
# codebase"). Only ignore the user-scoped .claude/ directory here.
.claude/

# Node
node_modules/

# RN sample app build outputs (generated by gradle / xcodebuild / pod install)
examples/*/ios/Pods/
examples/*/ios/Podfile.lock
examples/*/ios/build/
examples/*/android/build/
examples/*/android/app/build/
examples/*/android/.gradle/
examples/*/android/.kotlin/
examples/*/ios/RnSample.xcworkspace/
examples/*/.bundle/

# Sample app secrets / local-only state
examples/*/android/local.properties

# Sample app: pulled-in artifacts (if the sample copies them rather than referencing parent)
examples/*/android/app/src/main/jniLibs/
examples/*/android/app/src/main/java/uniffi/
examples/*/ios/PqcCore.xcframework/

# Native examples (NativeAndroid / NativeIos) — Gradle/Xcode build outputs.
# Their layout differs from RnSample's (Gradle root is the example dir itself),
# so they need their own patterns.
examples/NativeAndroid/.gradle/
examples/NativeAndroid/.kotlin/
examples/NativeAndroid/build/
examples/NativeAndroid/app/build/
examples/NativeAndroid/local.properties
examples/NativeIos/build/
examples/NativeIos/DerivedData/
examples/NativeIos/*.xcodeproj/xcuserdata/
examples/NativeIos/*.xcodeproj/project.xcworkspace/xcuserdata/
examples/*/ios/RnSample/pqc.swift
