# Rust
target/
**/*.rs.bk

# UniFFI generated artifacts (regenerate from source)
generated/

# IDE
.idea/
.vscode/
*.iml

# macOS
.DS_Store

# Android — Gradle build outputs and tooling caches for the library
# module rooted at android/.
android/build/
android/.gradle/
android/.kotlin/
android/local.properties
local.properties

# iOS
ios/build/
*.xcuserstate
xcuserdata/

# Logs / scratch
*.log
.scratch/

# Claude Code local files (per-user, not committed)
.claude/
CLAUDE.md

# Node
node_modules/

# RN sample app build outputs (generated by gradle / xcodebuild / pod install)
examples/*/ios/Pods/
examples/*/ios/Podfile.lock
examples/*/ios/build/
examples/*/android/build/
examples/*/android/app/build/
examples/*/android/.gradle/
examples/*/android/.kotlin/
examples/*/ios/RnSample.xcworkspace/
examples/*/.bundle/

# Sample app secrets / local-only state
examples/*/android/local.properties

# Sample app: pulled-in artifacts (if the sample copies them rather than referencing parent)
examples/*/android/app/src/main/jniLibs/
examples/*/android/app/src/main/java/uniffi/
examples/*/ios/PqcCore.xcframework/
examples/*/ios/RnSample/pqc.swift

# Auto-extracted upstream jars (rustls-platform-verifier Kotlin glue,
# pulled out of the vendored Maven AAR by scripts/build-android.sh).
# Regenerated on every build; not source.
android/libs/
