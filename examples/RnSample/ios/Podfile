# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# The sample app must target React Native's own minimum (RN 0.76 =>
# iOS 15.1); its core pods (hermes-engine, fmt, glog) declare a 15.1
# floor, so pinning the app below that breaks the Hermes build with a
# "'hermes/hermes.h' file not found" error. Use RN's macro so this
# tracks the installed RN version automatically.
#
# This is independent of PqcCore.podspec's `s.platform = :ios, '13.0'`:
# that is the LIBRARY's floor (it supports iOS 13.0+), which a 15.1 app
# consumes without conflict. Don't conflate the library floor with the
# sample app's deployment target.
platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'RnSample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # pqc-mobile-client via the local podspec at the repo root. PqcCore.podspec
  # references `pqc.swift` and `PqcCore.xcframework` (bare) so the release-zip
  # consumer path Just Works; for this local :path mode, `scripts/build-ios.sh`
  # creates matching symlinks at the repo root pointing into `generated/`.
  # Run `./scripts/build-ios.sh` first or `pod install` will fail to find them.
  pod 'PqcCore', :path => '../../../'

  target 'RnSampleTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
